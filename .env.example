# Auth.js
# Generate with: openssl rand -base64 32
# WARNING: changing this after launch invalidates all existing sessions.
AUTH_SECRET=replace-with-a-new-random-secret

# Supabase
# Create a project at supabase.com, then find these under Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # keep secret — never expose to client

# Identity verification (sybil resistance)
# HMAC key for hashing phone numbers in verified_identifiers.
# Generate with: openssl rand -base64 32
# WARNING: changing this after launch invalidates all existing verifications.
IDENTITY_SECRET=replace-with-a-new-random-secret

# Vote integrity pepper
# Mixed into SHA256 vote hashes alongside the client-side device_salt.
# Generate with: openssl rand -base64 32
# WARNING: changing this after launch breaks all existing vote deduplication.
VOTE_PEPPER=replace-with-a-new-random-secret

# Resend (email — optional for now)
RESEND_API_KEY=re_replace_me
EMAIL_FROM=Fair Say NZ <noreply@yourdomain.co.nz>

# Stripe (payments — optional for now)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
